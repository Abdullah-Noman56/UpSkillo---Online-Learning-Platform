<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= currentContent.lesson_title %> - <%= course.title %></title>
    <style>
        :root {
            --primary: #667eea;
            --primary-dark: #5a6fd8;
            --secondary: #764ba2;
            --success: #10b981;
            --success-dark: #059669;
            --warning: #f59e0b;
            --danger: #ef4444;
            --gray-50: #f9fafb;
            --gray-100: #f3f4f6;
            --gray-200: #e5e7eb;
            --gray-300: #d1d5db;
            --gray-600: #4b5563;
            --gray-700: #374151;
            --gray-800: #1f2937;
            --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
            --shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
            --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body { 
            font-family: 'Inter', 'Segoe UI', Arial, sans-serif; 
            margin: 0; 
            padding: 0; 
            background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
            min-height: 100vh;
            color: var(--gray-800);
            line-height: 1.6;
        }

        .header { 
            background: white; 
            padding: 1.5rem 2rem; 
            box-shadow: var(--shadow);
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 100;
            backdrop-filter: blur(10px);
        }

        .header h1 {
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-size: 1.8rem;
            font-weight: 700;
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .nav { 
            background: linear-gradient(135deg, var(--primary), var(--secondary)); 
            padding: 1rem 2rem; 
            box-shadow: var(--shadow);
        }

        .nav a { 
            color: white; 
            text-decoration: none; 
            margin-right: 2rem;
            font-weight: 500;
            padding: 0.5rem 1rem;
            border-radius: 8px;
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
        }

        .nav a:hover { 
            background: rgba(255, 255, 255, 0.15);
            transform: translateY(-1px);
        }

        .container { 
            max-width: 1200px; 
            margin: 2rem auto; 
            padding: 0 1.5rem;
            display: flex;
            gap: 2rem;
        }

        .sidebar { 
            flex: 1; 
            background: white; 
            padding: 2rem; 
            border-radius: 16px;
            box-shadow: var(--shadow);
            max-width: 350px;
            height: fit-content;
            position: sticky;
            top: 120px;
        }

        .content { 
            flex: 2; 
            background: white; 
            padding: 2.5rem; 
            border-radius: 16px;
            box-shadow: var(--shadow);
        }

        .content-item { 
            padding: 1.25rem; 
            border: 1px solid var(--gray-200); 
            margin: 0.5rem 0; 
            border-radius: 12px; 
            cursor: pointer; 
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        .content-item:hover { 
            background: var(--gray-50);
            transform: translateX(5px);
            border-color: var(--primary);
        }

        .content-item.completed { 
            background: #f0fdf4; 
            border-color: #bbf7d0;
            border-left: 4px solid var(--success);
        }

        .content-item.current { 
            background: #eff6ff; 
            border-color: var(--primary);
            border-left: 4px solid var(--primary);
        }

        .btn { 
            padding: 0.75rem 1.5rem; 
            background: var(--primary); 
            color: white; 
            border: none; 
            border-radius: 8px; 
            cursor: pointer; 
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            font-weight: 500;
            transition: all 0.3s ease;
            font-size: 0.9rem;
        }

        .btn:hover { 
            background: var(--primary-dark);
            transform: translateY(-2px);
            box-shadow: var(--shadow);
        }

        .btn-success {
            background: var(--success);
        }

        .btn-success:hover {
            background: var(--success-dark);
        }

        .btn-secondary {
            background: var(--gray-600);
        }

        .btn-secondary:hover {
            background: var(--gray-700);
        }

        .btn-outline {
            background: transparent;
            border: 2px solid var(--primary);
            color: var(--primary);
        }

        .btn-outline:hover {
            background: var(--primary);
            color: white;
        }

        .progress-bar { 
            background: var(--gray-200); 
            border-radius: 10px; 
            height: 12px; 
            margin: 1rem 0; 
            overflow: hidden;
        }

        .progress-fill { 
            background: linear-gradient(135deg, var(--success), var(--success-dark)); 
            height: 100%; 
            border-radius: 10px; 
            transition: width 0.5s ease;
        }

        .navigation { 
            display: flex; 
            justify-content: space-between; 
            margin-top: 3rem; 
            padding-top: 2rem; 
            border-top: 1px solid var(--gray-200); 
        }

        .completion-section { 
            background: linear-gradient(135deg, #f0fdf4, #f0f9ff); 
            padding: 2rem; 
            border-radius: 16px; 
            margin: 2rem 0; 
            text-align: center;
            border-left: 4px solid var(--success);
        }

        .lesson-content { 
            background: linear-gradient(135deg, #eff6ff, #f0f9ff); 
            padding: 2.5rem; 
            border-radius: 16px; 
            text-align: center; 
            margin: 2rem 0;
            border: 2px dashed var(--primary);
        }

        .feedback-section {
            background: linear-gradient(135deg, #fffbeb, #fef3c7);
            padding: 2rem;
            border-radius: 16px;
            margin: 2rem 0;
            border-left: 4px solid var(--warning);
        }

        .role-badge {
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            color: white;
            padding: 0.25rem 0.75rem;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: capitalize;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .fade-in {
            animation: fadeIn 0.6s ease-out;
        }

        @media (max-width: 768px) {
            .container {
                flex-direction: column;
                padding: 0 1rem;
            }
            
            .sidebar {
                max-width: none;
                position: static;
            }
            
            .nav {
                padding: 1rem;
                overflow-x: auto;
            }
            
            .nav a {
                margin-right: 1rem;
                font-size: 0.9rem;
            }
            
            .navigation {
                flex-direction: column;
                gap: 1rem;
            }
            
            .navigation .btn {
                width: 100%;
                text-align: center;
            }
        }
    </style>
</head>
<body>
    <div class="header">
        <h1>🎓 UpSkillo</h1>
        <div class="user-info">
            <span>Welcome, <strong><%= user.name %></strong> <span class="role-badge"><%= user.type %></span></span>
            <a href="/logout" class="btn btn-outline" style="padding: 0.5rem 1rem; font-size: 0.85rem;">🚪 Logout</a>
        </div>
    </div>
    
    <div class="nav">
        <a href="/dashboard">📊 Dashboard</a>
        <a href="/courses">📚 Browse Courses</a>
        <a href="/my-learning">🎓 My Learning</a>
        <a href="/learn/<%= course.id %>">📖 Back to Course</a>
    </div>
    
    <div class="container">
        <div class="sidebar fade-in">
            <h3 style="margin-bottom: 1.5rem; color: var(--gray-800); display: flex; align-items: center; gap: 0.5rem;">📚 Course Content</h3>
            
            <div id="progress-section" style="margin-bottom: 2rem;">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
                    <span style="font-weight: 600; color: var(--gray-700);">Progress</span>
                    <span id="progress-text" style="font-weight: 700; color: var(--success);">0%</span>
                </div>
                <div class="progress-bar">
                    <div class="progress-fill" id="progress-fill" style="width: 0%;"></div>
                </div>
            </div>
            
            <div id="content-list">
                <% content.forEach((item, index) => { %>
                    <div class="content-item <%= item.is_completed ? 'completed' : '' %> <%= item.id === currentContent.id ? 'current' : '' %>"
                         onclick="window.location.href='/learn/<%= course.id %>/content/<%= item.id %>'">
                        <div style="display: flex; align-items: flex-start; gap: 0.75rem;">
                            <% if (item.is_completed) { %>
                                <span style="color: var(--success); font-weight: bold; flex-shrink: 0;">✓</span>
                            <% } else { %>
                                <span style="color: var(--gray-400); flex-shrink: 0;">○</span>
                            <% } %>
                            <div style="flex: 1;">
                                <div style="font-weight: 600; color: var(--gray-800); margin-bottom: 0.25rem;">
                                    Lesson <%= index + 1 %>
                                </div>
                                <div style="font-size: 0.9em; color: var(--gray-600); line-height: 1.4;">
                                    <%= item.lesson_title %>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }); %>
            </div>
        </div>
        
        <div class="content fade-in">
            <div style="margin-bottom: 2rem;">
                <a href="/learn/<%= course.id %>" class="btn btn-secondary">← Back to Course</a>
            </div>
            
            <h1 style="margin-bottom: 1rem; color: var(--gray-800);"><%= currentContent.lesson_title %></h1>
            
            <% if (currentContent.description) { %>
                <div style="background: var(--gray-50); padding: 1.5rem; border-radius: 12px; margin: 1.5rem 0; border-left: 4px solid var(--primary);">
                    <h3 style="margin-bottom: 0.75rem; color: var(--gray-800); display: flex; align-items: center; gap: 0.5rem;">📋 Lesson Overview</h3>
                    <p style="line-height: 1.6; color: var(--gray-700);"><%= currentContent.description %></p>
                </div>
            <% } %>
            
            <!-- Lesson Content -->
            <div class="lesson-content">
                <h3 style="margin-bottom: 1rem; color: var(--primary);">🎥 Lesson Content</h3>
                <p style="color: var(--gray-700); margin-bottom: 1.5rem;">This is where your lesson video/content would be displayed.</p>
                
                <% if (currentContent.filename) { %>
                    <div style="background: var(--primary); color: white; padding: 1.5rem; border-radius: 12px; margin: 1.5rem 0;">
                        <h4 style="margin-bottom: 0.5rem;">📁 Resource Available</h4>
                        <p style="margin: 0; opacity: 0.9;"><strong>File:</strong> <%= currentContent.filename %></p>
                    </div>
                <% } else { %>
                    <div style="background: var(--primary); color: white; padding: 2rem; border-radius: 12px; margin: 1.5rem 0; max-width: 400px; margin-left: auto; margin-right: auto;">
                        <div style="font-size: 3rem; margin-bottom: 1rem;">📺</div>
                        <h4 style="margin-bottom: 0.5rem;">Video Player</h4>
                        <p style="opacity: 0.9; margin: 0;">Your lesson video would play here</p>
                    </div>
                <% } %>
            </div>
            
            <!-- Completion Section -->
            <div class="completion-section">
                <% if (currentContent.is_completed) { %>
                    <div style="color: var(--success); font-size: 1.25rem; margin-bottom: 1rem; display: flex; align-items: center; justify-content: center; gap: 0.5rem;">
                        ✅ You've completed this lesson!
                    </div>
                    <button class="btn btn-secondary" onclick="markAsComplete()" disabled style="opacity: 0.7;">
                        🎉 Already Completed
                    </button>
                <% } else { %>
                    <h3 style="margin-bottom: 1rem; color: var(--success);">🚀 Ready to move forward?</h3>
                    <p style="color: var(--gray-700); margin-bottom: 1.5rem;">Mark this lesson as complete to track your progress</p>
                    <button class="btn btn-success" onclick="markAsComplete()" id="complete-btn" style="min-width: 200px;">
                        ✅ Mark as Complete
                    </button>
                <% } %>
            </div>
            
            <!-- Recommendation Feedback -->
            <div class="feedback-section">
                <h3 style="margin-bottom: 1rem; color: var(--warning); display: flex; align-items: center; gap: 0.5rem;">💡 Help Us Improve</h3>
                <p style="color: var(--gray-700); margin-bottom: 1.5rem;">How would you rate this lesson for recommendations?</p>
                <form action="/add-feedback/<%= course.id %>" method="POST" style="display: flex; gap: 1rem; align-items: center; flex-wrap: wrap;">
                    <select name="feedback" style="padding: 0.75rem; border-radius: 8px; border: 1px solid var(--gray-300); background: white; flex: 1; min-width: 200px;">
                        <option value="like">👍 I like this content</option>
                        <option value="dislike">👎 Not what I expected</option>
                        <option value="too_easy">😴 Too easy</option>
                        <option value="too_hard">😓 Too hard</option>
                        <option value="just_right">👌 Just right</option>
                    </select>
                    <button type="submit" class="btn" style="background: var(--warning); color: var(--gray-800);">Submit Feedback</button>
                </form>
            </div>
            
            <!-- Navigation -->
            <div class="navigation">
                <% if (prevContent) { %>
                    <a href="/learn/<%= course.id %>/content/<%= prevContent.id %>" class="btn btn-secondary">
                        ← Previous: <%= prevContent.lesson_title %>
                    </a>
                <% } else { %>
                    <span></span>
                <% } %>
                
                <% if (nextContent) { %>
                    <a href="/learn/<%= course.id %>/content/<%= nextContent.id %>" class="btn btn-success">
                        Next: <%= nextContent.lesson_title %> →
                    </a>
                <% } else { %>
                    <a href="/learn/<%= course.id %>" class="btn btn-success">
                        🎉 Course Complete!
                    </a>
                <% } %>
            </div>
        </div>
    </div>

    <script>
        // Load progress
        async function loadProgress() {
            try {
                const response = await fetch('/api/progress/<%= course.id %>');
                const data = await response.json();
                
                if (data.percentage !== undefined) {
                    document.getElementById('progress-text').textContent = data.percentage + '%';
                    document.getElementById('progress-fill').style.width = data.percentage + '%';
                }
            } catch (error) {
                console.error('Error loading progress:', error);
            }
        }
        
        // Mark content as complete
        async function markAsComplete() {
            const btn = document.getElementById('complete-btn');
            if (btn) {
                btn.disabled = true;
                btn.textContent = 'Marking...';
                btn.style.opacity = '0.7';
            }
            
            try {
                const response = await fetch('/complete-lesson/<%= currentContent.id %>', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    }
                });
                
                const data = await response.json();
                
                if (data.success) {
                    // Show success message
                    const completionSection = document.querySelector('.completion-section');
                    completionSection.innerHTML = `
                        <div style="color: var(--success); font-size: 1.25rem; margin-bottom: 1rem; display: flex; align-items: center; justify-content: center; gap: 0.5rem;">
                            ✅ ${data.message}
                        </div>
                        <button class="btn btn-secondary" disabled style="opacity: 0.7;">
                            🎉 Already Completed
                        </button>
                    `;
                    
                    // Reload progress
                    setTimeout(loadProgress, 500);
                } else { 
                    alert('Error: ' + data.error);
                    if (btn) {
                        btn.disabled = false;
                        btn.textContent = '✅ Mark as Complete';
                        btn.style.opacity = '1';
                    }
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Network error. Please try again.');
                if (btn) {
                    btn.disabled = false;
                    btn.textContent = '✅ Mark as Complete';
                    btn.style.opacity = '1';
                }
            }
        }
        
        // Add subtle animations
        document.addEventListener('DOMContentLoaded', function() {
            const items = document.querySelectorAll('.content-item');
            items.forEach((item, index) => {
                item.style.animationDelay = `${index * 0.1}s`;
            });
            loadProgress();
        });
    </script>
</body>
</html>