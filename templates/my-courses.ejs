<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Courses - UpSkillo</title>
    <style>
        :root {
            --primary: #667eea;
            --primary-dark: #5a6fd8;
            --secondary: #764ba2;
            --success: #10b981;
            --success-dark: #059669;
            --warning: #f59e0b;
            --danger: #ef4444;
            --gray-50: #f9fafb;
            --gray-100: #f3f4f6;
            --gray-200: #e5e7eb;
            --gray-300: #d1d5db;
            --gray-600: #4b5563;
            --gray-700: #374151;
            --gray-800: #1f2937;
            --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
            --shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
            --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body { 
            font-family: 'Inter', 'Segoe UI', Arial, sans-serif; 
            background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
            min-height: 100vh;
            color: var(--gray-800);
            line-height: 1.6;
        }

        .header { 
            background: white; 
            padding: 1.5rem 2rem; 
            box-shadow: var(--shadow);
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .header h1 {
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-size: 1.8rem;
            font-weight: 700;
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .role-badge {
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            color: white;
            padding: 0.25rem 0.75rem;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: capitalize;
        }

        .nav { 
            background: linear-gradient(135deg, var(--primary), var(--secondary)); 
            padding: 1rem 2rem; 
            box-shadow: var(--shadow);
        }

        .nav a { 
            color: white; 
            text-decoration: none; 
            margin-right: 2rem;
            font-weight: 500;
            padding: 0.5rem 1rem;
            border-radius: 8px;
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
        }

        .nav a:hover { 
            background: rgba(255, 255, 255, 0.15);
            transform: translateY(-1px);
        }

        .container { 
            max-width: 1200px; 
            margin: 2rem auto; 
            padding: 0 1.5rem;
        }

        .page-header {
            background: white;
            padding: 2rem;
            border-radius: 16px;
            box-shadow: var(--shadow);
            margin-bottom: 2rem;
            border-left: 4px solid var(--primary);
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: relative;
            overflow: hidden;
        }

        .page-header::before {
            content: '';
            position: absolute;
            top: 0;
            right: 0;
            width: 150px;
            height: 150px;
            background: linear-gradient(135deg, rgba(102, 126, 234, 0.1), rgba(118, 75, 162, 0.1));
            border-radius: 50%;
            transform: translate(50%, -50%);
        }

        .page-header h2 {
            font-size: 2rem;
            color: var(--gray-800);
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin: 0;
        }

        .courses-grid { 
            display: grid; 
            grid-template-columns: repeat(auto-fill, minmax(380px, 1fr)); 
            gap: 1.5rem; 
            margin-bottom: 2rem;
        }

        .course-card { 
            background: white; 
            padding: 1.5rem; 
            border-radius: 12px; 
            box-shadow: var(--shadow);
            transition: all 0.3s ease;
            border: 1px solid var(--gray-200);
            position: relative;
            overflow: hidden;
        }

        .course-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
        }

        .course-card:hover {
            transform: translateY(-5px);
            box-shadow: var(--shadow-lg);
        }

        .course-card h3 {
            font-size: 1.3rem;
            margin-bottom: 0.75rem;
            color: var(--gray-800);
            line-height: 1.4;
        }

        .course-description {
            color: var(--gray-600);
            line-height: 1.5;
            margin-bottom: 1rem;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .course-stats {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 0.75rem;
            margin: 1rem 0;
            padding: 1rem 0;
            border-top: 1px solid var(--gray-200);
            border-bottom: 1px solid var(--gray-200);
        }

        .stat-item {
            text-align: center;
            padding: 0.5rem;
            background: var(--gray-50);
            border-radius: 8px;
            border: 1px solid var(--gray-200);
        }

        .stat-value {
            font-size: 1.2rem;
            font-weight: 700;
            color: var(--primary);
            display: block;
        }

        .stat-label {
            font-size: 0.75rem;
            color: var(--gray-600);
            margin-top: 0.25rem;
        }

        .course-meta {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin: 1rem 0;
            font-size: 0.85rem;
            color: var(--gray-600);
        }

        .category-tag {
            background: #e0f2fe;
            color: #0369a1;
            padding: 0.4rem 0.8rem;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 600;
            display: inline-block;
            margin-bottom: 1rem;
        }

        .btn { 
            padding: 0.75rem 1.5rem; 
            background: var(--primary); 
            color: white; 
            border: none; 
            border-radius: 8px; 
            cursor: pointer; 
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            font-weight: 500;
            transition: all 0.3s ease;
            font-size: 0.9rem;
            flex: 1;
        }

        .btn:hover { 
            background: var(--primary-dark);
            transform: translateY(-2px);
            box-shadow: var(--shadow);
        }

        .btn-success {
            background: var(--success);
        }

        .btn-success:hover {
            background: var(--success-dark);
        }

        .btn-secondary {
            background: var(--gray-600);
        }

        .btn-secondary:hover {
            background: var(--gray-700);
        }

        .btn-outline {
            background: transparent;
            border: 2px solid var(--primary);
            color: var(--primary);
        }

        .btn-outline:hover {
            background: var(--primary);
            color: white;
        }

        .course-actions {
            display: flex;
            gap: 0.75rem;
            margin-top: 1rem;
        }

        .course-actions .btn {
            flex: 1;
            min-width: 100px;
        }

        .empty-state {
            text-align: center;
            padding: 4rem 2rem;
            background: white;
            border-radius: 16px;
            box-shadow: var(--shadow);
            grid-column: 1 / -1;
        }

        .empty-state h3 {
            color: var(--gray-700);
            margin-bottom: 1rem;
            font-size: 1.5rem;
        }

        .empty-state p {
            color: var(--gray-600);
            margin-bottom: 2rem;
            max-width: 400px;
            margin-left: auto;
            margin-right: auto;
        }

        .error { 
            color: var(--danger); 
            padding: 1rem 1.5rem;
            background: #fef2f2;
            border-radius: 8px;
            margin-bottom: 1.5rem;
            border-left: 4px solid var(--danger);
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-weight: 500;
        }

        .teacher-stats {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1.5rem;
            margin-bottom: 2rem;
        }

        .stat-card {
            background: white;
            padding: 1.5rem;
            border-radius: 12px;
            box-shadow: var(--shadow);
            text-align: center;
            border-top: 4px solid var(--primary);
            transition: transform 0.3s ease;
        }

        .stat-card:hover {
            transform: translateY(-3px);
        }

        .stat-number {
            font-size: 2rem;
            font-weight: 700;
            color: var(--primary);
            margin: 0.5rem 0;
            display: block;
        }

        .stat-label-large {
            color: var(--gray-600);
            font-size: 0.9rem;
            font-weight: 500;
        }

        .stat-icon {
            font-size: 2rem;
            margin-bottom: 0.5rem;
            opacity: 0.8;
        }

        .course-performance {
            background: var(--gray-50);
            padding: 0.75rem;
            border-radius: 8px;
            margin-top: 0.5rem;
            border: 1px solid var(--gray-200);
        }

        .performance-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0.5rem 0;
            font-size: 0.85rem;
        }

        .performance-item:not(:last-child) {
            border-bottom: 1px solid var(--gray-200);
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .fade-in {
            animation: fadeIn 0.6s ease-out;
        }

        @media (max-width: 768px) {
            .container {
                padding: 0 1rem;
            }
            
            .nav {
                padding: 1rem;
                overflow-x: auto;
            }
            
            .nav a {
                margin-right: 1rem;
                font-size: 0.9rem;
            }
            
            .courses-grid {
                grid-template-columns: 1fr;
            }
            
            .course-actions {
                flex-direction: column;
            }
            
            .page-header {
                flex-direction: column;
                gap: 1rem;
                text-align: center;
            }
            
            .teacher-stats {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media (max-width: 480px) {
            .header {
                padding: 1rem 1.5rem;
                flex-direction: column;
                gap: 1rem;
                text-align: center;
            }
            
            .user-info {
                flex-direction: column;
                gap: 0.5rem;
            }
            
            .page-header h2 {
                font-size: 1.5rem;
            }
            
            .teacher-stats {
                grid-template-columns: 1fr;
            }
            
            .course-stats {
                grid-template-columns: 1fr;
                gap: 0.5rem;
            }
        }
    </style>
</head>
<body>
    <div class="header">
        <h1>🎓 UpSkillo</h1>
        <div class="user-info">
            <span>Welcome, <strong><%= user.name %></strong> <span class="role-badge"><%= user.type %></span></span>
            <a href="/logout" class="btn btn-outline" style="padding: 0.5rem 1rem; font-size: 0.85rem;">🚪 Logout</a>
        </div>
    </div>
    
    <div class="nav">
        <a href="/dashboard">📊 Dashboard</a>
        <a href="/courses">📚 Browse Courses</a>
        <a href="/create-course">✨ Create Course</a>
        <a href="/my-courses">📖 My Courses</a>
    </div>
    
    <div class="container">
        <div class="page-header fade-in">
            <h2>📖 My Teaching Courses</h2>
            <a href="/create-course" class="btn btn-success">
                ✨ Create New Course
            </a>
        </div>

        <!-- Teacher Statistics -->
        <div class="teacher-stats fade-in">
            <div class="stat-card">
                <div class="stat-icon">📚</div>
                <div class="stat-number"><%= courses.length %></div>
                <div class="stat-label-large">Total Courses</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon">👨‍🎓</div>
                <div class="stat-number">
                    <% 
                        let totalStudents = 0;
                        courses.forEach(course => {
                            totalStudents += course.enrollment_count || 0;
                        });
                    %>
                    <%= totalStudents %>
                </div>
                <div class="stat-label-large">Total Students</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon">📝</div>
                <div class="stat-number">
                    <% 
                        let totalContent = 0;
                        courses.forEach(course => {
                            totalContent += course.content_count || 0;
                        });
                    %>
                    <%= totalContent %>
                </div>
                <div class="stat-label-large">Total Content</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon">⭐</div>
                <div class="stat-number">
                    <% 
                        const ratedCourses = courses.filter(c => c.avg_rating);
                        const avgRating = ratedCourses.length > 0 ? 
                            (ratedCourses.reduce((acc, course) => acc + course.avg_rating, 0) / ratedCourses.length).toFixed(1) : 
                            '0.0';
                    %>
                    <%= avgRating %>
                </div>
                <div class="stat-label-large">Avg Rating</div>
            </div>
        </div>
        
        <% if (error) { %>
            <div class="error fade-in">
                ⚠️ <%= error %>
            </div>
        <% } %>
        
        <% if (courses.length === 0) { %>
            <div class="empty-state fade-in">
                <h3>📚 No Courses Created Yet</h3>
                <p>Start sharing your knowledge and inspiring students by creating your first course. Build your teaching portfolio and make an impact!</p>
                <a href="/create-course" class="btn btn-success" style="display: inline-flex; width: auto; padding: 1rem 2rem;">
                    ✨ Create Your First Course
                </a>
            </div>
        <% } else { %>
            <div class="courses-grid">
                <% courses.forEach(course => { 
                    const contentCount = course.content_count || 0;
                    const completionRate = contentCount > 0 ? Math.round((contentCount / 10) * 100) : 0;
                %>
                    <div class="course-card fade-in">
                        <div class="category-tag">
                            <%= course.category || 'General' %>
                        </div>
                        
                        <h3><%= course.title %></h3>
                        <p class="course-description">
                            <%= course.description && course.description.length > 120 ? 
                                course.description.substring(0, 120) + '...' : 
                                course.description || 'No description available' %>
                        </p>

                        <% if (course.filename) { %>
                            <div style="margin: 0.5rem 0; font-size: 0.85rem; color: var(--gray-600);">
                                📎 <strong>Material:</strong> <%= course.filename %>
                            </div>
                        <% } %>
                        
                        <div class="course-stats">
                            <div class="stat-item">
                                <span class="stat-value"><%= course.enrollment_count || 0 %></span>
                                <span class="stat-label">Students</span>
                            </div>
                            <div class="stat-item">
                                <span class="stat-value"><%= course.content_count || 0 %></span>
                                <span class="stat-label">Content</span>
                            </div>
                            <div class="stat-item">
                                <span class="stat-value">
                                    <% if (course.avg_rating) { %>
                                        <%= parseFloat(course.avg_rating).toFixed(1) %>
                                    <% } else { %>
                                        N/A
                                    <% } %>
                                </span>
                                <span class="stat-label">Rating</span>
                            </div>
                        </div>

                        <div class="course-performance">
                            <div class="performance-item">
                                <span>Content Progress</span>
                                <span style="font-weight: 600; color: var(--success);"><%= completionRate %>%</span>
                            </div>
                            <div class="performance-item">
                                <span>Student Engagement</span>
                                <span style="font-weight: 600; color: var(--warning);">
                                    <% if ((course.enrollment_count || 0) === 0) { %>
                                        Low
                                    <% } else if ((course.enrollment_count || 0) < 5) { %>
                                        Medium
                                    <% } else { %>
                                        High
                                    <% } %>
                                </span>
                            </div>
                            <div class="performance-item">
                                <span>Created</span>
                                <span style="color: var(--gray-600);"><%= new Date(course.created_at).toLocaleDateString() %></span>
                            </div>
                        </div>
                        
                        <div class="course-actions">
                            <a href="/add-lesson/<%= course.id %>" class="btn btn-success">
                                ➕ Add Content
                            </a>
                            <a href="/course/<%= course.id %>" class="btn">
                                👀 View
                            </a>
                            <a href="#" class="btn btn-secondary">
                                ⚙️ Manage
                            </a>
                        </div>
                    </div>
                <% }); %>
            </div>
        <% } %>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Add staggered animation to course cards
            const courseCards = document.querySelectorAll('.course-card');
            courseCards.forEach((card, index) => {
                card.style.animationDelay = `${index * 0.1}s`;
            });

            // Add hover effects to stat cards
            const statCards = document.querySelectorAll('.stat-card');
            statCards.forEach(card => {
                card.addEventListener('mouseenter', function() {
                    this.style.transform = 'translateY(-5px)';
                });
                card.addEventListener('mouseleave', function() {
                    this.style.transform = 'translateY(-3px)';
                });
            });

            // Update engagement indicators based on student count
            courseCards.forEach(card => {
                const students = parseInt(card.querySelector('.stat-value').textContent);
                const engagement = card.querySelector('.performance-item:nth-child(2) span:last-child');
                
                if (students === 0) {
                    engagement.textContent = 'Low';
                    engagement.style.color = 'var(--danger)';
                } else if (students < 5) {
                    engagement.textContent = 'Medium';
                    engagement.style.color = 'var(--warning)';
                } else {
                    engagement.textContent = 'High';
                    engagement.style.color = 'var(--success)';
                }
            });
        });
    </script>
</body>
</html>